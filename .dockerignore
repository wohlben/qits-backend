# Build context trim for `docker build -f docker/qits/Dockerfile .` (the app image, root context).
# Keep everything the reactor build needs (sources, pom.xml, mvnw + .mvn/, service/src/main/webui);
# drop what it doesn't so the context streamed to the daemon stays small and carries no stale output.
#
# Note: the app image build skips tests AND the derive-fixture-bares antrun (-Dqits.dev-guard.skip),
# so the git submodules under domain/src/test/resources/fixtures are never needed — a plain shallow
# clone (no --recurse-submodules) builds fine, and .git can be dropped here.
.git
.gitmodules

# Maven / Quarkus build output (regenerated inside the build stage)
**/target
**/target-ide

# Node / Angular build output + deps (Quinoa re-runs pnpm inside the build stage)
**/node_modules
service/src/main/webui/dist
service/src/main/webui/.angular

# Local env / IDE cruft
.env
.idea
.vscode

# Deployment scaffolding + docs — not needed to compile the app, and keeping them out of the context
# means an edit to install.sh / the compose file / docs doesn't bust the app image's `COPY . .` layer
# (so app-only rebuilds stay cache-fast).
install.sh
docker-compose*.yml
.github
docs
**/*.md
