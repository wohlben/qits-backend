{
  "name": "qits-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --serve-path \"${QITS_PUBLIC_BASE:-/}\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:visual": "ng run qits-ui:test-visual",
    "lint": "ng lint",
    "generate:api": "openapi-generator-cli generate -g typescript-angular -i openapi.yml -o src/app/api --additional-properties=ngVersion=21.2.0,supportsES6=true,providedInRoot=true,strictNullChecks=true,basePath=/"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@qits/angular"
    ],
    "packageExtensions": {
      "@opentelemetry/instrumentation-user-interaction": {
        "peerDependenciesMeta": {
          "zone.js": {
            "optional": true
          }
        }
      }
    }
  },
  "dependencies": {
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@ng-icons/core": "^33.2.2",
    "@ng-icons/lucide": "^33.2.2",
    "@ngrx/signals": "^21.1.0",
    "@qits/angular": "git+https://github.com/wohlben/qits-angular-integration.git#50f8e5fe9ef0f39369c63e4af13d3148c972d217",
    "@tanstack/angular-query-experimental": "^5.100.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff2html": "^3.4.56",
    "marked": "^18.0.5",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/schematics": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@openapitools/openapi-generator-cli": "^2.20.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.9"
  }
}