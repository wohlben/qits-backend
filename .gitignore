# Starter migration scratch file — written to the repo root by `cli generate-migration`
# as a reminder/template; turn it into a hand-written db/migration/V#__name.sql, then delete it.
PENDING_MIGRATION.sql

# Local per-machine Quarkus config overrides (e.g. WSL2 git-host); never committed.
.env

# IDE (m2e/jdtls) build output — kept separate from Maven's target/ so the language server
# never clobbers target/classes (see the m2e-separate-output profile in pom.xml).
target-ide/

# Sibling working clone of the @qits/angular integration library (its own repository,
# github.com/wohlben/qits-angular-integration) — checked out here for convenience, never part of qits.
/qits-angular-integration/
